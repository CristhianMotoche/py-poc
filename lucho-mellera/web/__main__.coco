from flask import Flask, render_template

import json

app = Flask(__name__)

@app.route("/", methods=["GET"])
def home():
  with open("shows.json", 'r') as f:
    shows = f.read() |> json.loads
    return render_template(
       "index.html",
        cities=shows |> map$((x) => x['place'] |> set)
    )


if __name__ == "__main__":
    app.run(debug=True)
